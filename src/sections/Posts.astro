---
// Posts-D: Video Gallery Feed - Focado em análise visual e mídias curtas
import { getAllPosts } from '../lib/posts';
interface Props { title: string; limit: number; btnText: string; btnLink: string; }
const { title, limit, btnText, btnLink } = Astro.props;

const posts = (await getAllPosts()).slice(0, limit);
---
<section class="py-24 bg-dark text-white overflow-hidden">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-4">
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary/10 text-primary border border-primary/20 rounded-lg text-[10px] font-black uppercase tracking-widest mb-4">
          <span class="flex h-1.5 w-1.5 rounded-full bg-primary animate-pulse"></span>
          Galeria de Análise
        </div>
        <h2 class="text-4xl md:text-5xl font-black tracking-tighter leading-none">{title}</h2>
      </div>
      <a href={btnLink} class="text-sm font-bold text-white/50 hover:text-primary transition-colors uppercase tracking-widest">
        {btnText} →
      </a>
    </div>

    <!-- Video Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {posts.map(post => (
        <article class="group relative aspect-[9/16] bg-gray-900 rounded-3xl overflow-hidden shadow-2xl border border-white/5 hover:border-primary/50 transition-all duration-500">
          <a href={`/${post.slug}`} class="block h-full w-full">
            <!-- Thumbnail img -->
            {post.heroImage && (
              <img
                src={post.heroImage}
                alt={post.title}
                class="w-full h-full object-cover opacity-60 group-hover:opacity-100 group-hover:scale-110 transition-all duration-700"
                loading="lazy"
              />
            )}
            
            <!-- Video Overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-dark/90 via-transparent to-transparent flex flex-col justify-end p-6">
              <div class="w-12 h-12 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center border border-white/30 mb-4 group-hover:bg-primary group-hover:border-primary transition-all duration-500 transform group-hover:scale-110">
                 <svg class="w-6 h-6 text-white fill-current" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              </div>
              
              <h3 class="text-lg font-black leading-tight mb-2 group-hover:text-primary transition-colors">
                {post.title}
              </h3>
              <div class="text-[10px] font-bold text-white/40 uppercase tracking-widest flex items-center gap-2">
                 <span>{post.category || 'Reels'}</span>
                 <span class="w-1 h-1 rounded-full bg-white/20"></span>
                 <span>{new Date(post.pubDate).toLocaleDateString('pt-BR', { month: 'short', year: 'numeric' })}</span>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>